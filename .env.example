# GLPI API
GLPI_URL=https://your-glpi-url/apirest.php/
GLPI_APP_TOKEN=your_app_token_here
GLPI_USER_TOKEN=your_user_token_here
GLPI_AUTH_USER=sync_bot
GLPI_AUTH_PASS=your_password

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=C:/path/to/service-account.json
SHEET_ID=your_google_sheet_id_here

# Sync config
SYNC_INTERVAL_MINUTES=10
LOG_LEVEL=INFO
