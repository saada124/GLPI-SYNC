# GLPI API
GLPI_URL=https://your-glpi-url/apirest.php/
GLPI_APP_TOKEN=your_app_token_here
GLPI_USER_TOKEN=your_user_token_here

# Google Sheets (via Apps Script web app — no service account needed)
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your-deployment-id/exec
SHEETS_AUTH_TOKEN=my-secret-sync-token-123

# Sync config
SYNC_INTERVAL_MINUTES=10
LOG_LEVEL=INFO
